{
    "formatters": {
        "enable": [
            "gofmt",
            "gofumpt"
        ],
        "exclusions": {
            "generated": "lax",
            "paths": [
                ".*\\.my\\.go$",
                "lib/bad.go",
                ".make",
                ".vscode",
                "dist",
                "third_party$",
                "builtin$"
            ]
        },
        "settings": {
            "gci": {
                "sections": [
                    "standard",
                    "default",
                    "prefix(github.com/mrz1836/hush)"
                ]
            },
            "gofmt": {
                "simplify": true
            },
            "gofumpt": {
                "extra-rules": false,
                "module-path": "github.com/mrz1836/hush"
            },
            "goimports": {
                "local-prefixes": [
                    "github.com/mrz1836/hush"
                ]
            }
        }
    },
    "issues": {
        "exclude-rules": [
            {
                "linters": [
                    "gomoddirectives"
                ],
                "source": "replace github.com/mrz1836/hush/functions/pkg/config"
            }
        ],
        "uniq-by-line": true
    },
    "linters": {
        "disable": [
            "gocritic",
            "godot",
            "gomoddirectives",
            "wsl_v5"
        ],
        "enable": [
            "asasalint",
            "arangolint",
            "depguard",
            "asciicheck",
            "bidichk",
            "bodyclose",
            "containedctx",
            "contextcheck",
            "copyloopvar",
            "dogsled",
            "durationcheck",
            "embeddedstructfieldcheck",
            "err113",
            "errcheck",
            "errchkjson",
            "errname",
            "errorlint",
            "exhaustive",
            "forbidigo",
            "funcorder",
            "gocheckcompilerdirectives",
            "gochecknoglobals",
            "gochecknoinits",
            "gochecksumtype",
            "gocognit",
            "goconst",
            "gocyclo",
            "godox",
            "goheader",
            "gomoddirectives",
            "gosec",
            "gosmopolitan",
            "govet",
            "inamedparam",
            "ineffassign",
            "loggercheck",
            "makezero",
            "mirror",
            "misspell",
            "musttag",
            "nakedret",
            "nestif",
            "nilerr",
            "nilnesserr",
            "nilnil",
            "noctx",
            "nolintlint",
            "nosprintfhostport",
            "prealloc",
            "predeclared",
            "protogetter",
            "reassign",
            "recvcheck",
            "revive",
            "rowserrcheck",
            "spancheck",
            "sqlclosecheck",
            "staticcheck",
            "testifylint",
            "unconvert",
            "unparam",
            "unused",
            "wastedassign",
            "zerologlint"
        ],
        "exclusions": {
            "rules": [
                {
                    "linters": [
                        "err113",
                        "gocognit",
                        "gocyclo",
                        "govet",
                        "gosec",
                        "staticcheck",
                        "nolintlint"
                    ],
                    "path": "internal/audit/.*_test\\.go"
                },
                {
                    "linters": [
                        "err113",
                        "gocognit",
                        "gocyclo",
                        "govet",
                        "gosec",
                        "unparam",
                        "errchkjson",
                        "nolintlint"
                    ],
                    "path": "internal/server/(secret_handler_test|revoke_handler_test|health_handler_test|audit_adapter_test)\\.go"
                },
                {
                    "linters": [
                        "goconst",
                        "err113",
                        "errcheck",
                        "gosec",
                        "nolintlint",
                        "testifylint"
                    ],
                    "path": "_test\\.go"
                }
            ]
        },
        "settings": {
            "depguard": {
                "rules": {
                    "no-testutil-in-production": {
                        "deny": [
                            {
                                "desc": "internal/testutil is a test-only package; import only from *_test.go files",
                                "pkg": "github.com/mrz1836/hush/internal/testutil"
                            }
                        ],
                        "files": [
                            "$all",
                            "!$test"
                        ],
                        "list-mode": "lax"
                    }
                }
            },
            "dogsled": {
                "max-blank-identifiers": 3
            },
            "dupl": {
                "threshold": 100
            },
            "exhaustive": {
                "default-signifies-exhaustive": false
            },
            "funcorder": {
                "constructor-after-struct": true
            },
            "funlen": {
                "lines": 60,
                "statements": 40
            },
            "gocognit": {
                "min-complexity": 10
            },
            "goconst": {
                "min-len": 3,
                "min-occurrences": 10
            },
            "gocyclo": {
                "min-complexity": 10
            },
            "godox": {
                "keywords": [
                    "NOTE",
                    "OPTIMIZE",
                    "HACK",
                    "ATTN",
                    "ATTENTION"
                ]
            },
            "gomoddirectives": {
                "replace-allow-list": [
                    "github.com/joho/godotenv",
                    "hush/functions/pkg/config"
                ],
                "replace-local-by-relative-path": false
            },
            "govet": {
                "enable": [
                    "atomicalign",
                    "shadow"
                ],
                "settings": {
                    "printf": {
                        "funcs": [
                            "(github.com/golangci/golangci-lint/pkg/logutils.Log).Infof",
                            "(github.com/golangci/golangci-lint/pkg/logutils.Log).Warnf",
                            "(github.com/golangci/golangci-lint/pkg/logutils.Log).Errorf",
                            "(github.com/golangci/golangci-lint/pkg/logutils.Log).Fatalf"
                        ]
                    }
                }
            },
            "lll": {
                "line-length": 120,
                "tab-width": 1
            },
            "misspell": {
                "ignore-rules": [
                    "bsv",
                    "bitcoin",
                    "synchronised",
                    "unsynchronised",
                    "categorise",
                    "categoriser",
                    "categorises",
                    "serialise",
                    "serialised",
                    "behaviour",
                    "honoured",
                    "cancelled"
                ],
                "locale": "US"
            },
            "nakedret": {
                "max-func-lines": 30
            },
            "nestif": {
                "min-complexity": 4
            },
            "nolintlint": {
                "allow-unused": false,
                "require-explanation": true,
                "require-specific": true
            },
            "prealloc": {
                "for-loops": false,
                "range-loops": true,
                "simple": true
            },
            "revive": {
                "rules": [
                    {
                        "arguments": [
                            [],
                            [],
                            [
                                {
                                    "skipPackageNameChecks": true
                                }
                            ]
                        ],
                        "name": "var-naming"
                    }
                ]
            },
            "unparam": {
                "check-exported": false
            },
            "wsl": {
                "allow-assign-and-call": true,
                "allow-cuddle-declarations": true,
                "allow-multiline-assign": true,
                "strict-append": true
            }
        }
    },
    "output": {
        "formats": {
            "text": {
                "path": "stdout",
                "print-issued-lines": true,
                "print-linter-name": true
            }
        }
    },
    "run": {
        "allow-parallel-runners": true,
        "build-tags": [
            "mage"
        ],
        "concurrency": 8,
        "issues-exit-code": 1,
        "tests": true
    },
    "severity": {
        "default": "warning",
        "rules": [
            {
                "linters": [
                    "dupl",
                    "misspell",
                    "makezero"
                ],
                "severity": "info"
            }
        ]
    },
    "version": "2"
}
