# ================================================================================================
# 🏗️ PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for hush
# Load Order: 90 (loaded after all defaults, overrides tool-specific settings)
#
# This file contains project-specific configuration that overrides defaults from
# earlier env files (00-core, 10-*, 20-*). Only values that differ from defaults
# need to be specified here.
#
# Maintainer: @mrz1836
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.26.x
GO_SECONDARY_VERSION=1.26.x

# ================================================================================================
# 🪄 MAGE-X GO VERSION OVERRIDES
# ================================================================================================

MAGE_X_GO_VERSION=1.26.x
MAGE_X_GO_SECONDARY_VERSION=1.26.x

# ================================================================================================
# 📊 COVERAGE PROVIDER
# ================================================================================================

# Use Codecov for coverage reporting (overrides 10-coverage.env default of 'internal')
GO_COVERAGE_PROVIDER=codecov
CODECOV_TOKEN_REQUIRED=true

# Coverage exclusions matching codecov.yml ignore paths
GO_COVERAGE_EXCLUDE_PATHS=test/,vendor/,testdata/,.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/

# ================================================================================================
# 🏗️ BUILD TAG CONFIGURATION
# ================================================================================================

# Exclude windows + linux build tags from auto-discovery (macOS incompatible)
# Prevents MAGE-X from testing with cross-OS build tags on macOS hosts,
# which causes Go compiler conflicts with zgoos_*/cpu_*_*.go files when
# the user-supplied -tags <os> diverges from the real GOOS.
MAGE_X_AUTO_DISCOVER_BUILD_TAGS_EXCLUDE=race,custom,windows,linux

# ================================================================================================
# 🛡️ SECURITY EXCLUSIONS
# ================================================================================================

# Nancy CVE Exclusions
# CVE-2023-42319: go-ethereum GraphQL DoS - no official fix available
# Safe to exclude: hush is a CLI wallet tool and doesn't expose GraphQL endpoints
# Ethereum team states GraphQL endpoint is "not designed for hostile clients"
NANCY_EXCLUDES=CVE-2023-42319

# ================================================================================================
# 🧪 TEST CONFIGURATION
# ================================================================================================

# Increase fuzz test timeout to prevent context deadline exceeded errors in CI
TEST_TIMEOUT_FUZZ=10m

# Ensure magex gives enough buffer for the fuzz tests to complete
MAGE_X_FUZZ_MIN_TIMEOUT=1m

